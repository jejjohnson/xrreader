# =============================================================================
# .env.example  —  copy to .env and fill in your values
# =============================================================================
# Run:  make init
# This file is committed to git.  .env is gitignored.
# =============================================================================

# ---------------------------------------------------------------------------
# Package / path overrides
# These match the Makefile defaults; only set them if you want a different value.
# ---------------------------------------------------------------------------
PKGROOT=src/xrreader

# ---------------------------------------------------------------------------
# Data adapter credentials (xrreader.*)
# Uncomment and fill in only the services you actually use.
# ---------------------------------------------------------------------------

# --- AEMET OpenData (Spanish meteorological service) -----------------------
# Request a free key: https://opendata.aemet.es/centrodedescargas/obtencionAPIKey
# Used by: xrreader.AemetSource, xrreader.AemetArchive
# AEMET_API_KEY=

# --- Copernicus Marine (CMEMS) ---------------------------------------------
# Register at https://data.marine.copernicus.eu/register
# Used by: xrreader.CMEMSSource
# COPERNICUSMARINE_SERVICE_USERNAME=
# COPERNICUSMARINE_SERVICE_PASSWORD=

# --- Climate Data Store (CDS / ECMWF) --------------------------------------
# Register at https://cds.climate.copernicus.eu/
# Used by: xrreader.CDSSource, xrreader.CDSInsituArchive
# (both ERA5 reanalysis and the in-situ surface-land / surface-marine products)
# CDSAPI_URL=https://cds.climate.copernicus.eu/api
# CDSAPI_KEY=

# --- Download cache directory (optional) -----------------------------------
# Where adapters cache downloaded subsets. Defaults to ~/.cache/xrreader.
# XRREADER_CACHE=

# ---------------------------------------------------------------------------
# Python tooling
# ---------------------------------------------------------------------------
# Override the uv-managed Python if needed (usually leave blank)
# PYTHON=python3.12

# ---------------------------------------------------------------------------
# CI / publishing configuration (fill in only if you use these)
# ---------------------------------------------------------------------------
# PyPI token (for use by your CI workflows or publishing tools)
# PYPI_TOKEN=

# GitHub personal access token (read:packages scope)
# GITHUB_TOKEN=
